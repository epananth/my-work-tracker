@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div>
                <div class="fw-semibold">My Work Tracker</div>
                <small class="text-body-secondary">Engineering work, PRs, epics, and tooling in one place</small>
            </div>
        </div>

        <article class="content px-4 pb-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
