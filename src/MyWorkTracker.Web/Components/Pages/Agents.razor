@page "/agents"
@rendermode InteractiveServer
@inject WorkTrackerApiClient Api

<PageTitle>Agents Registry</PageTitle>

<h1 class="mb-2">Agents, Skills, and Plugins</h1>
<p class="text-body-secondary mb-4">A registry of tracked automation assets with filters for type and lifecycle status.</p>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label class="form-label">Search</label>
                <input class="form-control" @bind="searchText" @bind:event="oninput" placeholder="Filter by name, description, or version" />
            </div>
            <div class="col-sm-6 col-lg-3">
                <label class="form-label">Type</label>
                <select class="form-select" value="@selectedType" @onchange="OnTypeChangedAsync">
                    @foreach (var type in TypeFilters)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="small text-body-secondary">Visible assets</div>
                <div class="fs-4 fw-semibold">@FilteredAgents.Count</div>
            </div>
            <div class="col-lg-2 d-grid">
                <button class="btn btn-outline-primary" @onclick="LoadAsync">Refresh</button>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <span>Loading registry...</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (FilteredAgents.Count == 0)
{
    <div class="alert alert-light border">No agents matched the current filter.</div>
}
else
{
    <div class="row g-3">
        @foreach (var agent in FilteredAgents)
        {
            <div class="col-md-6 col-xxl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between gap-3 align-items-start">
                            <div>
                                <div class="fw-semibold">@agent.Name</div>
                                <div class="small text-body-secondary">Added @agent.OnboardedAt.ToLocalTime().ToString("MMM d, yyyy")</div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-2">
                                <span class="badge @DisplayHelper.AgentTypeBadge(agent.Type)">@DisplayHelper.ToDisplayText(agent.Type)</span>
                                <span class="badge @DisplayHelper.AgentStatusBadge(agent.Status)">@DisplayHelper.ToDisplayText(agent.Status)</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(agent.Description))
                        {
                            <p class="small text-body-secondary mb-0">@agent.Description</p>
                        }

                        <div class="small d-flex flex-column gap-1">
                            <div><span class="text-body-secondary">Version:</span> @(string.IsNullOrWhiteSpace(agent.Version) ? "n/a" : agent.Version)</div>
                            @if (!string.IsNullOrWhiteSpace(agent.RepoUrl))
                            {
                                <div><a href="@agent.RepoUrl" target="_blank" rel="noreferrer">Repository</a></div>
                            }
                        </div>

                        @if (agent.Metadata.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                @foreach (var item in agent.Metadata.OrderBy(entry => entry.Key))
                                {
                                    <span class="badge rounded-pill text-bg-light">@item.Key: @item.Value</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private static readonly string[] TypeFilters = ["All", "Agent", "Skill", "Plugin"];

    private bool isLoading = true;
    private string? errorMessage;
    private string searchText = string.Empty;
    private string selectedType = "All";
    private IReadOnlyList<TrackedAgentDto> agents = [];

    private List<TrackedAgentDto> FilteredAgents => agents
        .Where(agent => string.IsNullOrWhiteSpace(searchText)
            || agent.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || (agent.Description?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (agent.Version?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(agent => agent.Type)
        .ThenBy(agent => agent.Name)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            agents = selectedType == "All"
                ? await Api.GetAgentsAsync()
                : await Api.GetAgentsByTypeAsync(selectedType);
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't load registry data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnTypeChangedAsync(ChangeEventArgs args)
    {
        selectedType = args.Value?.ToString() ?? "All";
        await LoadAsync();
    }
}
