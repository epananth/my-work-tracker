@page "/epics"
@rendermode InteractiveServer
@inject WorkTrackerApiClient Api

<PageTitle>Epic Tracker</PageTitle>

<h1 class="mb-2">Epic Tracker</h1>
<p class="text-body-secondary mb-4">Track progress across epics and see the highest priority next item for the selected stream of work.</p>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <span>Loading epics...</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="row g-4">
        <div class="col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Epics</span>
                    <button class="btn btn-sm btn-outline-primary" @onclick="LoadAsync">Refresh</button>
                </div>
                <div class="card-body">
                    @if (epics.Count == 0)
                    {
                        <div class="text-body-secondary">No epics available yet.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var epic in epics)
                            {
                                var total = epic.WorkItems.Count;
                                var done = epic.WorkItems.Count(item => item.Status == WorkItemStatus.Done);
                                var progress = total == 0 ? 0 : (int)Math.Round((double)done / total * 100);
                                var inFlight = epic.WorkItems.Count(item => item.Status is WorkItemStatus.InProgress or WorkItemStatus.InReview);

                                <div class="border rounded p-3 @(selectedEpicId == epic.Id ? "border-primary bg-primary-subtle" : "border-light-subtle")">
                                    <div class="d-flex justify-content-between gap-3 align-items-start mb-2">
                                        <div>
                                            <div class="fw-semibold">@epic.Title</div>
                                            <div class="small text-body-secondary">@epic.ExternalId • @(epic.TargetDate?.ToLocalTime().ToString("MMM d, yyyy") ?? "No target date")</div>
                                        </div>
                                        <button class="btn btn-sm @(selectedEpicId == epic.Id ? "btn-primary" : "btn-outline-primary")" @onclick="() => SelectEpicAsync(epic.Id)">
                                            What's next?
                                        </button>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(epic.Description))
                                    {
                                        <p class="small text-body-secondary mb-3">@epic.Description</p>
                                    }

                                    <div class="progress mb-2" role="progressbar" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar" style="width: @($"{progress}%")">@progress%</div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-3 small text-body-secondary">
                                        <span>@done / @total done</span>
                                        <span>@inFlight in flight</span>
                                        @if (!string.IsNullOrWhiteSpace(epic.Url))
                                        {
                                            <a href="@epic.Url" target="_blank" rel="noreferrer">Open epic</a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-body-tertiary">
                    <div class="fw-semibold">What's Next?</div>
                    @if (SelectedEpic is not null)
                    {
                        <div class="small text-body-secondary">Priority view for @SelectedEpic.Title</div>
                    }
                </div>
                <div class="card-body">
                    @if (SelectedEpic is null)
                    {
                        <div class="text-body-secondary">Select an epic to see the next recommended item.</div>
                    }
                    else if (isPriorityLoading)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <span>Loading prioritized work...</span>
                        </div>
                    }
                    else
                    {
                        @if (nextItem is null)
                        {
                            <div class="alert alert-light border">No prioritized next item is available for this epic yet.</div>
                        }
                        else
                        {
                            <div class="border rounded p-3 mb-4 bg-body-tertiary">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <div class="small text-body-secondary">Recommended next item</div>
                                        <div class="fw-semibold">
                                            @if (string.IsNullOrWhiteSpace(nextItem.Url))
                                            {
                                                @nextItem.Title
                                            }
                                            else
                                            {
                                                <a href="@nextItem.Url" target="_blank" rel="noreferrer">@nextItem.Title</a>
                                            }
                                        </div>
                                    </div>
                                    <span class="badge @DisplayHelper.WorkItemPriorityBadge(nextItem.Priority)">@DisplayHelper.ToDisplayText(nextItem.Priority)</span>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <span class="badge @DisplayHelper.WorkItemStatusBadge(nextItem.Status)">@DisplayHelper.ToDisplayText(nextItem.Status)</span>
                                    @foreach (var tag in nextItem.Tags)
                                    {
                                        <span class="badge rounded-pill text-bg-light">@tag</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(nextItem.Description))
                                {
                                    <p class="small text-body-secondary mb-0">@nextItem.Description</p>
                                }
                            </div>
                        }

                        <div class="fw-semibold mb-3">Prioritized backlog</div>
                        @if (prioritizedItems.Count == 0)
                        {
                            <div class="text-body-secondary">No ranked items returned for this epic.</div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var item in prioritizedItems.Take(5))
                                {
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between gap-3 align-items-start">
                                            <div>
                                                <div class="fw-semibold">@item.Title</div>
                                                <div class="small text-body-secondary">@DisplayHelper.ToDisplayText(item.Status)</div>
                                            </div>
                                            <span class="badge @DisplayHelper.WorkItemPriorityBadge(item.Priority)">@DisplayHelper.ToDisplayText(item.Priority)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isPriorityLoading;
    private string? errorMessage;
    private IReadOnlyList<EpicDto> epics = [];
    private int? selectedEpicId;
    private WorkItemDto? nextItem;
    private IReadOnlyList<WorkItemDto> prioritizedItems = [];

    private EpicDto? SelectedEpic => epics.FirstOrDefault(epic => epic.Id == selectedEpicId);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            epics = await Api.GetEpicsAsync();
            selectedEpicId = epics.FirstOrDefault(epic => epic.Id == selectedEpicId)?.Id ?? epics.FirstOrDefault()?.Id;

            if (selectedEpicId.HasValue)
            {
                await LoadPriorityAsync(selectedEpicId.Value);
            }
            else
            {
                nextItem = null;
                prioritizedItems = [];
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't load epic data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectEpicAsync(int epicId)
    {
        selectedEpicId = epicId;
        await LoadPriorityAsync(epicId);
    }

    private async Task LoadPriorityAsync(int epicId)
    {
        isPriorityLoading = true;
        errorMessage = null;

        try
        {
            var nextTask = Api.GetEpicNextAsync(epicId);
            var prioritizedTask = Api.GetEpicPrioritizedAsync(epicId);
            await Task.WhenAll(nextTask, prioritizedTask);

            nextItem = await nextTask;
            prioritizedItems = await prioritizedTask;
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't load prioritized work: {ex.Message}";
        }
        finally
        {
            isPriorityLoading = false;
        }
    }
}
