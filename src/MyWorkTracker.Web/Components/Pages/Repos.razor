@page "/repos"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject WorkTrackerApiClient Api

<PageTitle>Repo Onboarding</PageTitle>

<h1 class="mb-2">Repo Onboarding</h1>
<p class="text-body-secondary mb-4">Track repositories that should feed issues, pull requests, agents, and work items into the app.</p>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-body-tertiary fw-semibold">Add tracked repository</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <EditForm Model="repoForm" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="mb-3" />

                    <div class="mb-3">
                        <label class="form-label">Owner</label>
                        <InputText class="form-control" @bind-Value="repoForm.Owner" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Repository name</label>
                        <InputText class="form-control" @bind-Value="repoForm.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Platform</label>
                        <InputSelect class="form-select" @bind-Value="repoForm.Platform">
                            <option value="GitHub">GitHub</option>
                            <option value="AzureDevOps">Azure DevOps</option>
                        </InputSelect>
                    </div>

                    <div class="form-check mb-3">
                        <InputCheckbox class="form-check-input" @bind-Value="repoForm.IsActive" />
                        <label class="form-check-label">Active immediately</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@isSubmitting">
                        @(isSubmitting ? "Saving..." : "Add repository")
                    </button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Tracked repositories</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="LoadAsync">Refresh</button>
            </div>
            <div class="card-body p-0">
                @if (isLoading)
                {
                    <div class="p-4 d-flex align-items-center gap-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span>Loading repositories...</span>
                    </div>
                }
                else if (repos.Count == 0)
                {
                    <div class="p-4 text-body-secondary">No repositories have been onboarded yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Repository</th>
                                    <th>Platform</th>
                                    <th>Onboarded</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var repo in repos.OrderBy(repo => repo.Owner).ThenBy(repo => repo.Name))
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@repo.Owner/@repo.Name</div>
                                            <div class="small text-body-secondary">Repo ID @repo.Id</div>
                                        </td>
                                        <td>@repo.Platform</td>
                                        <td class="small text-body-secondary">@repo.OnboardedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                        <td>
                                            <span class="badge @(repo.IsActive ? "text-bg-success" : "text-bg-secondary")">@(repo.IsActive ? "Active" : "Inactive")</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;
    private IReadOnlyList<TrackedRepoDto> repos = [];
    private RepoFormModel repoForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            repos = await Api.GetReposAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't load repositories: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            await Api.AddRepoAsync(new TrackedRepoDto
            {
                Owner = repoForm.Owner.Trim(),
                Name = repoForm.Name.Trim(),
                Platform = repoForm.Platform,
                IsActive = repoForm.IsActive,
                OnboardedAt = DateTime.UtcNow
            });

            repoForm = new RepoFormModel();
            successMessage = "Repository added successfully.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't add repository: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class RepoFormModel
    {
        [Required]
        public string Owner { get; set; } = string.Empty;

        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        public string Platform { get; set; } = "GitHub";

        public bool IsActive { get; set; } = true;
    }
}
